# MAX Bot (from https://dev.max.ru)
BOT_TOKEN=

# OpenRouter (image generation + voice transcription)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_TIMEOUT=300

# Bitrix24 OAuth (server-side app)
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_DOMAIN=
BITRIX_REFRESH_TOKEN=
# Custom Bitrix field holding the MAX username (@handle).
BITRIX_MAX_FIELD=UF_USR_1678964886664

# Jira (integration user)
JIRA_URL=
JIRA_USERNAME=
JIRA_PASSWORD=

# OpenClaw (Glafira — AI office manager via browser)
OPENCLAW_URL=
OPENCLAW_TOKEN=
OPENCLAW_AGENT_ID=main

# Potok.io (Recruiter Anatoly)
POTOK_API_TOKEN=
POTOK_BASE_URL=https://app.potok.io

# Claude CLI (subscription-based, no API tokens)
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_REFRESH_TOKEN=

# Webhook (shared secret for incoming B24 webhooks)
WEBHOOK_TOKEN=

# Access control (comma-separated MAX user IDs)
GLAFIRA_ALLOWED=
RECRUITER_ALLOWED=

# Database
DB_PATH=data/arkadyjarvismax.db

# Scheduler
SUMMARY_HOUR=19
SUMMARY_MINUTE=0
TIMEZONE=Asia/Novosibirsk

# Wednesday frog meme (0 = disabled)
WEDNESDAY_FROG_CHAT_ID=0
# Monday motivational poster (0 = disabled)
MONDAY_POSTER_CHAT_ID=0

# Socrates (meeting analyser)
FFMPEG_BIN=ffmpeg
MEETING_MAX_MINUTES=90
